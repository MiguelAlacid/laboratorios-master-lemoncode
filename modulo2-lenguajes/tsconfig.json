{
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "outDir": "transpiled",
    "strict": true
  },
  "compileOnSave": true,
  "exclude": ["node_modules"],
  "include": ["src"]
}
